{$DOMAIN:localhost} {
	tls {$ACME_EMAIL:internal}

	# Deck content — served directly from mounted volume
	handle /deck/* {
		uri strip_prefix /deck
		root * /srv/content
		file_server
	}

	# WebSocket sync — local yjs-server
	handle /ws* {
		reverse_proxy localhost:1234 {
			header_up Upgrade {http.request.header.Upgrade}
			header_up Connection {http.request.header.Connection}
		}
	}

	# SPA shell
	handle {
		root * /srv/slides
		file_server
		try_files {path} /index.html
	}
}
