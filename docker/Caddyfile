{$DOMAIN:localhost} {
	tls {$ACME_EMAIL:internal}

	# Deck content — served directly from mounted volume
	handle /deck/* {
		uri strip_prefix /deck
		root * /srv/content
		file_server
	}

	# WebSocket sync — local yjs-server
	handle /ws* {
		reverse_proxy localhost:1234 {
			header_up Upgrade {http.request.header.Upgrade}
			header_up Connection {http.request.header.Connection}
		}
	}

	# Content proxy API — local yjs-server
	handle /api/* {
		reverse_proxy localhost:1234
	}

	# Short URL redirects — local yjs-server
	handle /s/* {
		reverse_proxy localhost:1234
	}

	# Hub — redirect bare /hub to /hub/ so the SPA base path resolves correctly,
	# then proxy all /hub/* traffic to the hub server.
	handle /hub {
		redir /hub/ 301
	}

	handle /hub/* {
		reverse_proxy localhost:3000
	}

	# SPA shell
	handle {
		root * /srv/slides
		file_server
		try_files {path} /index.html
	}
}
