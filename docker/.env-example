# =============================================================================
# GeekSlides — environment variables template
# Copy to .env and fill in all required values before running docker compose.
# .env is gitignored; never commit it.
# =============================================================================


# =============================================================================
# PRIVATE MACHINE — docker-compose.tailscale.yml
# =============================================================================

# --- Tailscale ---

# Auth key from https://login.tailscale.com/admin/settings/keys
# Use an ephemeral key with the tag:container tag pre-approved in ACLs.
TS_AUTHKEY=tskey-auth-REPLACE_ME

# Hostname that will appear on the tailnet (e.g. "gs" → gs.snow-burbot.ts.net)
TS_HOSTNAME=gs

# Your tailnet domain (shown in the Tailscale admin console under DNS)
# Used to build VIEWER_BASE_URL and COOKIE_DOMAIN when set here.
TS_TAILNET=snow-burbot.ts.net


# --- GeekSlides ---

# Host path to the deck directory (read-only mount into the container).
# If unset, the built-in welcome/help deck is shown by default.
# To serve your own deck, set this and uncomment the volume in docker-compose.tailscale.yml.
CONTENT_DIR=/path/to/deck/content


# --- Hub ---

# Full public URL that end users open — used in OAuth redirect URIs and
# email links.  Set to your public domain if behind the public Caddy proxy,
# or to the ts.net URL for private-only access.
VIEWER_BASE_URL=https://gs.aprender.cloud

# GitHub OAuth app credentials (leave blank to disable GitHub login)
# Callback URL to register in the OAuth app: ${VIEWER_BASE_URL}/hub/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth app credentials (leave blank to disable Google login)
# Callback URL to register in the OAuth app: ${VIEWER_BASE_URL}/hub/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Random secret used to sign JWT tokens — generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_ME_WITH_RANDOM_SECRET

# Email address of the initial admin user
ADMIN_EMAIL=admin@example.com

# Root domain for the session cookie.
# MUST match the domain your browser uses to reach the hub.
#   - Tailscale: set to your TS_TAILNET value  (e.g. snow-burbot.ts.net)
#   - Public:    set to your root domain        (e.g. aprender.cloud)
# If this is wrong the browser will reject the auth cookie and every login fails.
COOKIE_DOMAIN=snow-burbot.ts.net


# =============================================================================
# PUBLIC MACHINE — standalone Caddy 2 (no Docker)
# These variables are NOT used by docker-compose.tailscale.yml.
# Copy docker/caddy-public.env.example to /etc/caddy/environment on the
# public machine and fill in the values there.
# See how-to/16-deploy-with-tailscale.md for setup instructions.
# =============================================================================
