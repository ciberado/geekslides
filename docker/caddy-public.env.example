# =============================================================================
# Public machine — Caddy 2 environment variables
# Deploy to /etc/caddy/environment on the public machine.
# The caddy.service systemd unit loads this file via EnvironmentFile.
# See how-to/16-deploy-with-tailscale.md for full setup instructions.
# =============================================================================

# Public-facing domain (DNS A record must point to this machine's IP)
PUBLIC_DOMAIN=gs.aprender.cloud

# Let's Encrypt notification email
ACME_EMAIL=admin@example.com

# Tailscale FQDN of the private machine — TS_HOSTNAME.TS_TAILNET
# (visible in the Tailscale admin console under Machines)
PRIVATE_DOMAIN=gs.snow-burbot.ts.net
