# Dev reverse proxy — single entry point for all GeekSlides services.
# Listens on :8080 and routes to the three local dev servers:
#   /hub/*   → Hub Fastify server  :3000
#   /api/*   → yjs-server          :1234
#   /ws*     → yjs-server          :1234  (WebSocket)
#   /*       → viewer Vite SPA     :5173

:8080 {
	handle /ws* {
		reverse_proxy localhost:1234 {
			header_up Upgrade {http.request.header.Upgrade}
			header_up Connection {http.request.header.Connection}
		}
	}

	handle /api/* {
		reverse_proxy localhost:1234
	}

	handle /hub {
		redir /hub/ 301
	}

	handle /hub/* {
		reverse_proxy localhost:3000
	}

	handle {
		reverse_proxy localhost:5173
	}
}
