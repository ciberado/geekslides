{
  "name": "geekslides",
  "private": true,
  "type": "module",
  "description": "Geekslides is oriented towards creating effective remote presentations, specially for empowering learning experiences.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "npm run build -w @geekslides/server && npm run build -w @geekslides/cli",
    "dev": "concurrently --kill-others \"tsx packages/server/src/index.ts\" \"vite --config vite.config.ts --host 0.0.0.0\"",
    "dev:hub": "npm run dev -w @geekslides/hub",
    "build:hub": "npm run build -w @geekslides/hub",
    "dev:nosync": "vite --config vite.config.ts --host 0.0.0.0",
    "build": "npm run build -w @geekslides/engine && npm run build -w @geekslides/server && npm run build -w @geekslides/cli",
    "test": "vitest run",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "lint": "eslint .",
    "typecheck": "tsc --build",
    "docker:build": "npm run docker:build:main && npm run docker:build:server && npm run docker:build:cli && npm run docker:build:cli:chromium && npm run docker:build:hub",
    "docker:build:main": "docker build -t ciberado/geekslides:latest -f docker/Dockerfile .",
    "docker:build:server": "docker build -t ciberado/geekslides-server:latest -f docker/Dockerfile.server .",
    "docker:build:cli": "docker build --target slim -t ciberado/geekslides-cli:latest -f docker/Dockerfile.cli .",
    "docker:build:cli:chromium": "docker build --target chromium -t ciberado/geekslides-cli:chromium -f docker/Dockerfile.cli .",
    "docker:build:hub": "docker build -t ciberado/geekslides-hub:latest -f docker/Dockerfile.hub .",
    "docker:push": "npm run docker:push:main && npm run docker:push:server && npm run docker:push:cli && npm run docker:push:cli:chromium && npm run docker:push:hub",
    "docker:push:main": "docker push ciberado/geekslides:latest",
    "docker:push:server": "docker push ciberado/geekslides-server:latest",
    "docker:push:cli": "docker push ciberado/geekslides-cli:latest",
    "docker:push:cli:chromium": "docker push ciberado/geekslides-cli:chromium",
    "docker:push:hub": "docker push ciberado/geekslides-hub:latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^3.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.16.0",
    "jsdom": "^29.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ciberado/geekslides.git"
  },
  "author": "",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/ciberado/geekslides/issues"
  },
  "homepage": "https://github.com/ciberado/geekslides#readme"
}
