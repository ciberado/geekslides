{
  "name": "geekslides",
  "private": true,
  "type": "module",
  "description": "Geekslides is oriented towards creating effective remote presentations, specially for empowering learning experiences.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "npm run build -w @geekslides/server && npm run build -w @geekslides/cli && npm run build -w @geekslides/vscode",
    "start": "bash scripts/start-dev.sh",
    "dev": "concurrently --kill-others \"tsx packages/server/src/index.ts\" \"vite --config vite.config.ts --host 0.0.0.0\"",
    "dev:hub": "npm run dev -w @geekslides/hub",
    "build:plugins": "vite build --config plugins/vite.config.ts",
    "build:hub": "npm run build -w @geekslides/hub",
    "stop": "fuser -k 1234/tcp 5173/tcp 3000/tcp 3001/tcp 8080/tcp 2>/dev/null; true",
    "dev:nosync": "vite --config vite.config.ts --host 0.0.0.0",
    "build": "npm run build -w @geekslides/engine && npm run build -w @geekslides/server && npm run build -w @geekslides/cli && npm run build -w @geekslides/vscode",
    "test": "vitest run",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "lint": "eslint .",
    "typecheck": "tsc --build",
    "docker:build": "bash scripts/docker-build-push.sh --build",
    "docker:push": "bash scripts/docker-build-push.sh --push",
    "docker:build-push": "bash scripts/docker-build-push.sh",
    "docker:smoke": "bash scripts/docker-image-smoke.sh latest",
    "release": "bash scripts/release.sh",
    "release:dry": "bash scripts/release.sh --dry"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^3.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.16.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ciberado/geekslides.git"
  },
  "author": "",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/ciberado/geekslides/issues"
  },
  "homepage": "https://github.com/ciberado/geekslides#readme",
  "overrides": {
    "uuid": ">=14.0.0"
  }
}
