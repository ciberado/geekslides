{
  "name": "@geekslides/hub",
  "version": "2.6.2",
  "license": "Apache-2.0",
  "type": "module",
  "main": "src/server/index.ts",
  "types": "src/server/index.ts",
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:server": "esbuild src/server/index.ts --bundle --platform=node --format=cjs --outfile=dist/server/index.cjs --external:better-sqlite3 --external:pino --external:pino-pretty --external:thread-stream --external:jsdom",
    "build:smoke": "node scripts/bundle-smoke.mjs",
    "build:client": "vite build --config vite.client.config.ts",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server/index.cjs",
    "dev": "concurrently --kill-others \"tsx src/server/index.ts\" \"vite --config vite.client.config.ts --host 0.0.0.0\"",
    "test:e2e": "playwright test --config e2e/playwright.config.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^9.1.3",
    "adm-zip": "^0.5.16",
    "colz": "^0.1.0",
    "d3": "^7.9.0",
    "jszip": "^3.10.1",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.0",
    "isomorphic-git": "^1.27.0",
    "jsdom": "^29.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/d3": "^7.4.3",
    "@types/jsdom": "^28.0.3",
    "esbuild": "^0.25.12",
    "lit": "^3.2.0",
    "vite": "^6.0.0"
  }
}
