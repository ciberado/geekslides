{
  "name": "@geekslides/cli",
  "version": "2.0.0-alpha.0",
  "type": "module",
  "bin": {
    "geekslides": "dist/index.cjs"
  },
  "files": [
    "app",
    "dist"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && npm run build:types && npm run build:bin",
    "build:bin": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs --external:vite --external:sharp --external:playwright",
    "build:types": "tsc",
    "build:app": "vite build --config vite.app.config.ts",
    "typecheck": "tsc --noEmit",
    "dev": "vite --host 0.0.0.0"
  },
  "dependencies": {
    "@geekslides/engine": "*",
    "@geekslides/server": "*",
    "commander": "^13.0.0",
    "playwright": "^1.49.0",
    "sharp": "^0.33.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.12"
  }
}
